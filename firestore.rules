rules_version = '2';

// 청첩장 방명록(guestbook) / 참석 여부(rsvp) 컬렉션 규칙
// - 누구나 읽고 쓸 수 있도록 허용하되, 간단한 형식 검증을 둔다.
// - 운영 시에는 reCAPTCHA / App Check / 관리자 인증 등을 추가로 고려하세요.
service cloud.firestore {
  match /databases/{database}/documents {

    match /guestbook/{docId} {
      allow read: if true;
      allow create: if request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() < 30
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() < 500;
      allow update: if false;
      // 삭제: 작성자가 본인 글을 지울 수 있도록 허용(클라이언트가 localStorage 로
      // 본인 글 ID 를 기록해 본인 글에만 삭제 버튼 노출 → 기기 기준 보호, 보안 약함).
      // ⚠️ 강한 보안이 필요하면 Auth 기반 소유자 검증으로 확장 권장.
      allow delete: if true;
    }

    match /rsvp/{docId} {
      allow read: if false; // 응답은 신랑신부(관리자 콘솔)에서만 확인
      allow create: if request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.attending in ['yes', 'no'];
      allow update, delete: if false;
    }

    // 갤러리 업로드 사진 — 이미지는 Storage 에, Firestore 에는 url/path 만 저장.
    // 읽기 공개. 생성은 url 문자열 필요. 순서(order)만 변경 가능. 삭제 허용.
    // (과거 dataURL 문서도 읽기는 그대로 동작)
    match /gallery/{docId} {
      allow read: if true;
      allow create: if request.resource.data.url is string;
      allow update: if request.resource.data.url == resource.data.url;
      allow delete: if true;
    }

    // 커버 슬라이드쇼 — 갤러리와 동일.
    match /covers/{docId} {
      allow read: if true;
      allow create: if request.resource.data.url is string;
      allow update: if request.resource.data.url == resource.data.url;
      allow delete: if true;
    }

    // 게스트스냅 — 하객 누구나 업로드(공개). url 저장.
    // 삭제: 업로더(기기 기준) / 관리자 정리용으로 허용. 수정 금지.
    match /guestsnaps/{docId} {
      allow read: if true;
      allow create: if request.resource.data.url is string;
      allow update: if false;
      allow delete: if true;
    }
  }
}
