rules_version = '2';

// 청첩장 사진 저장소(Storage) 규칙
// - 읽기는 공개(하객이 사진을 봐야 함)
// - 쓰기는 이미지 파일 + 15MB 이하만 허용(가벼운 보호 — 비밀 URL/패스코드 수준)
// - 삭제 허용(관리자/업로더 정리용)
// ⚠️ 강한 보안이 필요하면 Firebase Auth 기반으로 확장 권장.
service firebase.storage {
  match /b/{bucket}/o {
    match /{folder}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if true;
    }
  }
}
