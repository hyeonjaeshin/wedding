# Firebase 웹 앱 설정값 (Firebase 콘솔 > 프로젝트 설정 > 일반 > 내 앱 에서 확인)
# 아래 값을 채운 뒤 이 파일을 ".env" 로 복사하세요.
# .env 파일은 .gitignore 에 의해 커밋되지 않습니다.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# (선택) 지도 연동용 키 - 카카오 또는 네이버 중 사용하는 쪽만 채우면 됩니다.
VITE_KAKAO_MAP_KEY=
VITE_NAVER_MAP_CLIENT_ID=

# 사진 업로드 관리자 페이지(#/admin) 패스코드. 미설정 시 기본값 'wedding1031'.
# (클라이언트 검증이라 번들에 노출됨 — 비밀 URL+패스코드 수준의 가벼운 보호)
VITE_ADMIN_PASSCODE=
